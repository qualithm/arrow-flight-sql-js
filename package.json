{
  "name": "@qualithm/arrow-flight-sql-js",
  "version": "0.3.0",
  "description": "Arrow Flight SQL client for JavaScript and TypeScript runtimes.",
  "private": false,
  "type": "module",
  "keywords": [
    "arrow",
    "apache-arrow",
    "flight",
    "flight-sql",
    "client",
    "javascript",
    "typescript"
  ],
  "license": "MIT",
  "author": "Qualithm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualithm/arrow-flight-sql-js.git"
  },
  "homepage": "https://github.com/qualithm/arrow-flight-sql-js#readme",
  "bugs": {
    "url": "https://github.com/qualithm/arrow-flight-sql-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    },
    "./transport": {
      "import": "./dist/transport.js",
      "types": "./dist/transport.d.ts"
    },
    "./transport/grpc-js": {
      "bun": "./dist/transport-grpc-js.js",
      "node": "./dist/transport-grpc-js.js",
      "import": "./dist/transport-grpc-js.js",
      "types": "./dist/transport-grpc-js.d.ts"
    },
    "./transport/grpc-web": {
      "browser": "./dist/transport-grpc-web.js",
      "import": "./dist/transport-grpc-web.js",
      "types": "./dist/transport-grpc-web.d.ts"
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run scripts/fix-imports.ts",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "dev": "bun --watch run src/index.ts",
    "docs": "typedoc",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "bun run clean && bun run build",
    "proto:generate": "bun run scripts/generate-proto.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:browser": "bunx playwright test",
    "test:browser:install": "bunx playwright install chromium",
    "test:coverage": "bun test --coverage",
    "test:integration": "bun test src/__tests__/integration",
    "test:unit": "bun test src/__tests__/unit",
    "test:watch": "bun test --watch",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "bench": "bun run benchmarks/index.ts",
    "analyze": "bun run scripts/analyze-bundle.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "apache-arrow": "21.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.58.2",
    "@types/bun": "1.3.9",
    "eslint": "9.39.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.3.0",
    "jiti": "2.6.1",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "typedoc": "0.28.16",
    "typedoc-plugin-markdown": "4.10.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0"
  }
}
