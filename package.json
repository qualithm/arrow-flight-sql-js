{
  "name": "@qualithm/arrow-flight-sql-js",
  "version": "0.0.1",
  "description": "Arrow Flight SQL client for JavaScript and TypeScript runtimes.",
  "private": false,
  "type": "module",
  "keywords": [
    "arrow",
    "apache-arrow",
    "flight",
    "flight-sql",
    "client",
    "javascript",
    "typescript"
  ],
  "license": "MIT",
  "author": "Qualithm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualithm/arrow-flight-sql-js.git"
  },
  "homepage": "https://github.com/qualithm/arrow-flight-sql-js#readme",
  "bugs": {
    "url": "https://github.com/qualithm/arrow-flight-sql-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "dev": "bun --watch run src/index.ts",
    "docs": "typedoc",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "bun run clean && bun run build",
    "proto:generate": "bun run scripts/generate-proto.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:integration": "bun test src/__tests__/integration",
    "test:unit": "bun test src/__tests__/unit",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@grpc/grpc-js": "1.14.3",
    "@grpc/proto-loader": "0.8.0",
    "apache-arrow": "21.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/bun": "1.3.7",
    "eslint": "9.39.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "globals": "17.2.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "typedoc": "0.28.16",
    "typedoc-plugin-markdown": "4.9.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0"
  }
}
