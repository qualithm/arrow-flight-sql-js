---
import Docs from "../layouts/Docs.astro"

const base = import.meta.env.BASE_URL
---

<Docs title="Arrow Flight SQL Client">
  <div class="my-12 text-center">
    <h1>Arrow Flight SQL Client for JavaScript</h1>
    <p class="text-xl text-[var(--fg-dim)]">
      A high-performance Arrow Flight SQL client for JavaScript/TypeScript with connection pooling,
      automatic retries, and comprehensive metrics.
    </p>
  </div>

  <h2 id="installation">Installation</h2>

  <pre><code class="language-bash">npm install @qualithm/arrow-flight-sql</code></pre>

  <p>Or with your preferred package manager:</p>

  <pre><code class="language-bash"># pnpm
pnpm add @qualithm/arrow-flight-sql

# bun
bun add @qualithm/arrow-flight-sql</code></pre>

  <h2 id="quick-start">Quick Start</h2>

  <pre><code class="language-typescript">{`import { FlightSqlClient } from "@qualithm/arrow-flight-sql"

const client = new FlightSqlClient({
  host: "localhost",
  port: 50051,
  credentials: {
    username: "user",
    password: "password"
  }
})

// Execute a query
const table = await client.query("SELECT * FROM my_table LIMIT 10")
console.log(table.toArray())

// Don't forget to close when done
await client.close()`}</code></pre>

  <h2 id="features">Features</h2>

  <ul>
    <li>
      <strong>Full Arrow Flight SQL Support</strong> — Query execution, prepared statements,
      transactions, and metadata operations
    </li>
    <li>
      <strong>Connection Pooling</strong> — Efficient connection reuse with configurable pool sizes
    </li>
    <li>
      <strong>Automatic Retries</strong> — Configurable retry policies with exponential backoff
    </li>
    <li>
      <strong>Comprehensive Metrics</strong> — Built-in metrics collection for monitoring and
      debugging
    </li>
    <li><strong>TypeScript First</strong> — Full type safety with detailed type definitions</li>
    <li><strong>Zero Dependencies Runtime</strong> — Only Apache Arrow and gRPC as peer deps</li>
  </ul>

  <h2 id="connection-pooling">Connection Pooling</h2>

  <pre><code class="language-typescript">{`import { ConnectionPool } from "@qualithm/arrow-flight-sql"

const pool = new ConnectionPool({
  host: "localhost",
  port: 50051,
  credentials: { username: "user", password: "password" },
  pool: {
    minConnections: 2,
    maxConnections: 10,
    acquireTimeout: 5000
  }
})

// Acquire connection from pool
const client = await pool.acquire()
try {
  const result = await client.query("SELECT * FROM users")
  // ... process result
} finally {
  pool.release(client)
}

// Or use withConnection for automatic release
await pool.withConnection(async (client) => {
  return client.query("SELECT * FROM orders")
})`}</code></pre>

  <div class="my-12 flex-row flex-wrap items-center justify-center gap-4">
    <a class="pill-md pill-solid" href={`${base}api/`}>
      View API Reference
    </a>
    <a
      class="pill-md pill-outline"
      href="https://github.com/qualithm/arrow-flight-sql-js"
    >
      View on GitHub
    </a>
  </div>
</Docs>
