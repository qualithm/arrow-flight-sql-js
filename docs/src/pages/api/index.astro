---
import Docs from "../../layouts/Docs.astro"

const base = import.meta.env.BASE_URL
---

<Docs title="API Reference">
  <div class="my-12 text-center">
    <h1>API Reference</h1>
    <p class="text-xl text-[var(--fg-dim)]">
      Complete API documentation for @qualithm/arrow-flight-sql-js.
    </p>
  </div>

  <h2>Classes</h2>
  <div class="my-8 grid grid-cols-1 gap-4 sm:grid-cols-2" data-wide>
    <a
      href={`${base}api/classes/FlightSqlClient/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">FlightSqlClient</h3>
      <p class="text-sm text-[var(--fg-dim)]">Main client for executing Flight SQL operations.</p>
    </a>
    <a
      href={`${base}api/classes/FlightSqlPool/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">FlightSqlPool</h3>
      <p class="text-sm text-[var(--fg-dim)]">
        Connection pool for managing multiple client connections.
      </p>
    </a>
    <a
      href={`${base}api/classes/RetryPolicy/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">RetryPolicy</h3>
      <p class="text-sm text-[var(--fg-dim)]">Configurable retry policy with exponential backoff.</p>
    </a>
  </div>

  <h2>Interfaces</h2>
  <div class="my-8 grid grid-cols-1 gap-4 sm:grid-cols-2" data-wide>
    <a
      href={`${base}api/interfaces/FlightSqlClientOptions/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">FlightSqlClientOptions</h3>
      <p class="text-sm text-[var(--fg-dim)]">Configuration options for the client.</p>
    </a>
    <a
      href={`${base}api/interfaces/RetryOptions/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">RetryOptions</h3>
      <p class="text-sm text-[var(--fg-dim)]">Options for configuring retry behaviour.</p>
    </a>
    <a
      href={`${base}api/interfaces/MetricsHandler/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">MetricsHandler</h3>
      <p class="text-sm text-[var(--fg-dim)]">Interface for custom metrics collection.</p>
    </a>
  </div>

  <h2>Error Classes</h2>
  <div class="my-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-wide>
    <a
      href={`${base}api/classes/FlightSqlError/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">FlightSqlError</h3>
      <p class="text-sm text-[var(--fg-dim)]">Base error class.</p>
    </a>
    <a
      href={`${base}api/classes/ConnectionError/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">ConnectionError</h3>
      <p class="text-sm text-[var(--fg-dim)]">Connection failures.</p>
    </a>
    <a
      href={`${base}api/classes/QueryError/`}
      class="rounded-2xl border border-[var(--border-dim)] p-6 text-center hover:border-[var(--link)] hover:bg-[var(--surface-dim)]"
    >
      <h3 class="text-[var(--fg-bright)]">QueryError</h3>
      <p class="text-sm text-[var(--fg-dim)]">Query execution errors.</p>
    </a>
  </div>
</Docs>
