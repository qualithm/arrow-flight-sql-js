---
const base = import.meta.env.BASE_URL

const sections = [
  {
    title: "Getting Started",
    items: [
      { title: "Introduction", href: `${base}` },
      { title: "Installation", href: `${base}#installation` },
      { title: "Quick Start", href: `${base}#quick-start` }
    ]
  },
  {
    title: "API Reference",
    items: [
      { title: "Overview", href: `${base}api/` },
      { title: "FlightSqlClient", href: `${base}api/classes/FlightSqlClient/` },
      { title: "FlightSqlPool", href: `${base}api/classes/FlightSqlPool/` },
      { title: "RetryPolicy", href: `${base}api/classes/RetryPolicy/` }
    ]
  }
]
---

<aside
  class="sticky top-14 hidden h-[calc(100vh-3.5rem)] w-64 shrink-0 justify-start self-start overflow-y-auto border-r border-[var(--border-dim)] lg:block"
>
  <div class="justify-start py-6">
    <nav class="justify-start gap-6 px-4">
      {
        sections.map((section) => (
          <div class="gap-2">
            <h4 class="px-3 text-xs font-semibold uppercase tracking-wider text-[var(--fg-dim)]">
              {section.title}
            </h4>
            <div class="gap-1">
              {section.items.map((item) => (
                <a class="pill-md pill-ghost justify-start" href={item.href}>
                  {item.title}
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </nav>
  </div>
</aside>
